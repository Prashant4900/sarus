generator client {
  provider = "dart run orm"
  output   = "."
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
    id Int @id @default(autoincrement())
    firstName String
    lastName String
    email String
    password String

    isActive Boolean
    isSuperAdmin Boolean

    createdAt DateTime @default(now())
    updatedAt DateTime

    @@unique([email])

    @@map("users")
}