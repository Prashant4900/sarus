generator client {
  provider = "dart run orm"
  output   = "."
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model {{name}} {
  id        Int    @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  @@unique([id])
  @@map("{{name}}")
}